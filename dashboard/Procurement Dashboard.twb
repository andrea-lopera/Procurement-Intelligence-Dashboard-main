    <worksheet name='KPIs/Values'>
      <table>
        <view>
          <datasources>
            <datasource caption='synthetic_procurement_orders' name='federated.1impv0n1pgl8zm13iucj91vytgnk' />
          </datasources>
          <datasource-dependencies datasource='federated.1impv0n1pgl8zm13iucj91vytgnk'>
            <column caption='COPQ ($)' datatype='real' name='[Calculation_1207949914298560512]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF[defect_flag]=1 THEN[total_cost_usd]END)' />
            </column>
            <column caption='Average PO Cycles' datatype='real' name='[Calculation_3100517287567851522]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([actual_lead_time_days])' />
            </column>
            <column caption='% On-Time Delivery' datatype='real' default-format='p0.00%' name='[Calculation_5604377943883100162]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([on_time_flag])/COUNT([on_time_flag])' />
            </column>
            <column caption='% Defects' datatype='real' name='[Calculation_5764185361926520832]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([defect_flag])/COUNT([defect_flag])' />
            </column>
            <column caption='Actual Lead Time Days' datatype='integer' name='[actual_lead_time_days]' role='measure' type='quantitative' />
            <column-instance column='[risk_score]' derivation='Avg' name='[avg:risk_score:qk]' pivot='key' type='quantitative' />
            <column aggregation='Sum' caption='Defect Flag' datatype='integer' name='[defect_flag]' role='dimension' type='ordinal' />
            <column aggregation='Sum' caption='On Time Flag' datatype='integer' name='[on_time_flag]' role='dimension' type='ordinal' />
            <column caption='Risk Score' datatype='real' name='[risk_score]' role='measure' type='quantitative' />
            <column-instance column='[total_cost_usd]' derivation='Sum' name='[sum:total_cost_usd:qk]' pivot='key' type='quantitative' />
