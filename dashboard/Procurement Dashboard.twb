          <alias key='&quot;[federated.1impv0n1pgl8zm13iucj91vytgnk].[usr:Calculation_3100517287567851522:qk]&quot;' value='Average PO Cycles (Days)' />
          <alias key='&quot;[federated.1impv0n1pgl8zm13iucj91vytgnk].[usr:Calculation_5604377943883100162:qk]&quot;' value='% ON-TIME DELIVERY' />
          <alias key='&quot;[federated.1impv0n1pgl8zm13iucj91vytgnk].[usr:Calculation_5764185361926520832:qk]&quot;' value='Defect Rate' />
        </aliases>
      </column>
      <column caption='COPQ ($)' datatype='real' name='[Calculation_1207949914298560512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF[defect_flag]=1 THEN[total_cost_usd]END)' />
      </column>
      <column caption='Box' datatype='string' name='[Calculation_1932536873409736704]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
      <column caption='Average PO Cycles' datatype='real' name='[Calculation_3100517287567851522]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([actual_lead_time_days])' />
      </column>
      <column caption='Lead Time Variance' datatype='integer' name='[Calculation_3100517287570251779]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[promised_lead_time_days]-[actual_lead_time_days]' />
      </column>
      <column caption='Defect Reason without Nulls' datatype='boolean' name='[Calculation_545076344097320961]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='ISNULL([defect_reason]) = FALSE' />
      </column>
      <column caption='% On-Time Delivery' datatype='real' default-format='p0.00%' name='[Calculation_5604377943883100162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([on_time_flag])/COUNT([on_time_flag])' />
      </column>
      <column caption='% Defects' datatype='real' name='[Calculation_5764185361926520832]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([defect_flag])/COUNT([defect_flag])' />
      </column>
      <column aggregation='None' caption='Lead Time Variance (bin)' datatype='integer' name='[Lead Time Variance (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Calculation_3100517287570251779]' peg='0' size='6' />
